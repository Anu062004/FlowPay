# Backend
PORT=4000
DATABASE_URL=postgresql://postgres:1234@172.23.119.206:5432/flowpay
RPC_URL=https://sepolia.infura.io/v3/{WDK_API_KEY}
WDK_API_KEY=your_wdk_or_rpc_key
WDK_TRANSFER_MAX_FEE=1000000000000000
MASTER_KEY=replace-with-strong-32-char-secret
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
PAYROLL_CRON=0 9 1 * *
INVESTMENT_CRON=0 */6 * * *
MAX_TX_AMOUNT=100000
TREASURY_PAYROLL_RESERVE_PCT=0.6
TREASURY_LENDING_PCT=0.2
TREASURY_INVESTMENT_PCT=0.2
PRICE_API_URL=
PRICE_API_KEY=
INVESTMENT_WALLET_ADDRESS=
SMTP_URL=smtp://user:pass@smtp.provider.com:587
EMAIL_FROM=FlowPay <no-reply@flowpay.local>
APP_BASE_URL=http://localhost:3000

# Blockchain (Hardhat)
PRIVATE_KEY=your_sepolia_private_key
